<Window x:Class="ChatBotApp.QuizPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ChatBotApp"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Foreground="{DynamicResource Theme_TextBrush}">

    <Grid Background="#FFF5E6" Width="655">
        <TextBlock FontSize="24" Margin="336,40,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="40" Text="Quiz By Cipher" />
        <TextBlock FontSize="14" Margin="25,107,0,0" Name="displayQuestion" HorizontalAlignment="Left" VerticalAlignment="Top" Height="46" Text="Question 1: What is the best way to prevent a cyber attack on your personal computer?" />
        <RadioButton Margin="112,168,0,0" Name="Option1" HorizontalAlignment="Left" VerticalAlignment="Top" Width="363" Height="32" Content="Option 1" />
        <RadioButton Margin="112,216,0,0" Name="Option2" HorizontalAlignment="Left" VerticalAlignment="Top" Width="363" Height="32" Content="Option 2" />
        <RadioButton Content="Option 3" Name="Option3" Margin="112,264,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="363" Height="32" />
        <RadioButton Content="Option 4" Name = "Option4" Margin="112,312,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="363" Height="32" />
        <TextBlock FontSize="14" Margin="541,326,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="24" Text="Score:" />
        <Button Margin="533,358,10,20" Name="nextQuestionBtn" HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="112" Height="32" Content="Next Question" Click="submitBtn_Click" />
        <TextBlock HorizontalAlignment="Left" Margin="112,366,0,0" TextWrapping="Wrap" Text="..." VerticalAlignment="Top" Name="feedbackText" Height="16" Width="97"/>
    </Grid>
</Window>
