<Window x:Class="ChatBotApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatBotApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto" Margin="10">
            <ItemsControl x:Name="ChatHistoryItems">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border   Margin="5" Padding="10" MaxWidth="280"
                                HorizontalAlignment="{Binding Alignment}"
                                Background="{Binding BackgroundColor}">
                            <TextBlock Text="{Binding MessageText}" TextWrapping="Wrap" Foreground="Black"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="1" Background="White" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="InputTextBox" Grid.Column="0" Height="35" 
                     VerticalContentAlignment="Center" Padding="5" Margin="0,0,10,0"
                     KeyDown="InputTextBox_KeyDown" BorderBrush="#CCCCCC" />

            <Button x:Name="SendButton" Grid.Column="1" Content="Send" Width="75" Height="35"
                    Click="SendButton_Click" Background="#007ACC" Foreground="White" 
                    FontWeight="Bold" BorderThickness="0"  />
        </Grid>
    </Grid>
</Window>
